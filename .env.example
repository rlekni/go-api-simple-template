# Application Insights Configuration
# Replace 'your-region' with your actual Azure region (e.g. westeurope-5, centralus)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# Database Configuration (for docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=tea_blends
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

# Application Configuration
APP_ENV=local
PORT=8080
