GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5432/tea_blends
GOOSE_MIGRATION_DIR=./postgresql/migrations/
#GOOSE_TABLE=migrations

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=tea_blends
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

# Application Configuration
APP_ENV=local
PORT=8080

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4319

# Application Insights Configuration
# Replace 'your-region' with your actual Azure region (e.g. westeurope-5, centralus)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/
